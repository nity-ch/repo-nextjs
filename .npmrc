link-workspace-packages=deep
prefer-workspace-packages=true

# @nity/ui is a private GitHub Releases tarball. GH_TOKEN must be a fine-grained PAT
# with "Contents: read" for nity-ch/repo-shared. This gives release download access
# without broader org permissions. Under the umbrella, pnpm links to local source instead.
//github.com/:_authToken=${GH_TOKEN}

# @nity/utils is published to npm — resolves from the default registry.
