link-workspace-packages=deep
prefer-workspace-packages=true

# @playground/* packages are published to both npm and GitHub Packages.
# By default (no override here), pnpm resolves them from npm.
# Team members who need GitHub Packages as the primary source can add:
#   @playground:registry=https://npm.pkg.github.com
#   //npm.pkg.github.com/:_authToken=${GH_TOKEN}
# to their personal ~/.npmrc. No change to this file is needed.
